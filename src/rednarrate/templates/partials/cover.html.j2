<section class="cover">
  <div class="cover-inner">
    <p class="classification">{{ meta.classification }}</p>
    <h1>{{ meta.report_title }}</h1>
    <h2 style="border:none; color:#1c1917;">{{ meta.client_name }}</h2>
    <p class="muted" style="margin-top:30mm;">
      Date: {{ meta.report_date }}<br>
      Version: {{ meta.version }}<br>
      Scope: {{ meta.scope }}<br>
      Engagement: {{ meta.engagement_dates }}
    </p>
    <p class="muted" style="margin-top:20mm; font-size:8pt;">
      Generated by RedNarrate. This document contains confidential security
      information and is intended solely for the named client.
    </p>
  </div>
</section>
