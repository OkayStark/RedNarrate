# Copy to .env and fill in. Never commit .env.

# LLM provider: "anthropic" (cloud) or "ollama" (local/offline)
REDNARRATE_LLM_PROVIDER=anthropic

# Anthropic API key (required when provider=anthropic)
ANTHROPIC_API_KEY=

# Model overrides (optional — sensible defaults baked in)
# Writer model: prose quality matters here
REDNARRATE_WRITER_MODEL=claude-opus-4-8
# Scoring model: high-volume constrained task, cheaper model
REDNARRATE_SCORING_MODEL=claude-haiku-4-5
# Correlation model: one call, moderate
REDNARRATE_CORRELATION_MODEL=claude-haiku-4-5

# Ollama (when provider=ollama)
REDNARRATE_OLLAMA_MODEL=llama3.1:8b
REDNARRATE_OLLAMA_BASE_URL=http://localhost:11434

# Paths
REDNARRATE_DB_PATH=rednarrate.db
REDNARRATE_CHROMA_DIR=chroma_db
REDNARRATE_OUTPUT_DIR=output
REDNARRATE_KNOWLEDGE_DIR=knowledge
